{
  "name": "@rush/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "check": "turbo check",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@rush/web",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
